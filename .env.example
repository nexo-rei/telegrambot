# ==============================================================================
# 1. BOT CONFIGURATION
# ==============================================================================
BOT_TOKEN=1234567890:ABCdefGhIJKlmNoPQRsTUVwxyZ_12345678
BOT_USERNAME=YourPremiumInvestmentBot
WEBHOOK_URL=https://api.yourdomain.com.ng/v1/telegram/webhook

# ==============================================================================
# 2. POSTGRESQL CONFIGURATION
# ==============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=investment_platform_db
DB_USER=postgres_admin_user
DB_PASSWORD=your_strong_production_db_password_here

# ==============================================================================
# 3. REDIS CONFIGURATION
# ==============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_auth_password_here
REDIS_DB=0

# ==============================================================================
# 4. SECURITY & CRYPTOGRAPHY
# ==============================================================================
# Generate secure strings using: openssl rand -hex 32
SECRET_KEY=fallback_session_cookie_signer_key_hash_value_here
JWT_SECRET=json_web_token_symmetric_signing_secret_key_here
# Fernet key must be a 32-byte base64-encoded string
ENCRYPTION_KEY=32_byte_base64_url_safe_fernet_secret_key_equals=
PASSWORD_SALT=static_system_password_hashing_salt_modifier_here

# ==============================================================================
# 5. PAYSTACK PAYMENT GATEWAY (NIGERIA / NGN)
# ==============================================================================
PAYSTACK_SECRET_KEY=sk_live_your_actual_paystack_secret_key_hex_string
PAYSTACK_PUBLIC_KEY=pk_live_your_actual_paystack_public_key_hex_string
PAYSTACK_WEBHOOK_SECRET=whsec_your_paystack_webhook_verification_token

# ==============================================================================
# 6. CELERY DISTRIBUTED TASK QUEUE
# ==============================================================================
CELERY_BROKER_URL=redis://:your_redis_password_here@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:your_redis_password_here@localhost:6379/2

# ==============================================================================
# 7. SCHEDULER CONFIGURATION
# ==============================================================================
TIMEZONE=Africa/Lagos

# ==============================================================================
# 8. LOGGING ENGINE CONFIGURATION
# ==============================================================================
LOG_LEVEL=INFO
LOG_PATH=/var/log/investment_platform

# ==============================================================================
# 9. LOCAL DATA & AMORTIZATION STORAGE
# ==============================================================================
STORAGE_PATH=/var/lib/investment_platform/storage
BACKUP_PATH=/var/lib/investment_platform/backups

# ==============================================================================
# 10. SYSTEM RUNTIME FEATURE FLAGS
# ==============================================================================
DEBUG=False
ENABLE_WEBHOOK=False
ENABLE_SCHEDULER=True
ENABLE_BACKUP=True
